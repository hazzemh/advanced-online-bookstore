# Copy this file to `.env` and fill values as needed.
# `.env` is git-ignored in this repo.

# Server
SERVER_PORT=8081

# Postgres (for docker-compose)
POSTGRES_DB=bookstore_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Redis (for docker-compose)
REDIS_PORT=6379

# App config
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# Cache
CACHE_TYPE=redis
REDIS_HOST=redis
CACHE_REDIS_TTL=10m

# JWT (required)
JWT_SECRET=change-me-change-me-change-me-change-me-change-me-change-me
JWT_EXPIRATION=86400000

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# Internal service-to-service token (required if you run payment-service against the monolith)
INTERNAL_API_TOKEN=change-me-internal-token

# Payment-service (docker-compose defaults)
PAYMENT_SERVER_PORT=8082
PAYMENT_POSTGRES_DB=bookstore_payment_db
PAYMENT_POSTGRES_USER=postgres
PAYMENT_POSTGRES_PASSWORD=postgres
PAYMENT_POSTGRES_PORT=5433

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

